E2y l\u1EDBn th\u01B0\u1EDDng xanh, l\u00E1 gi\u1ED1ng nh\u01B0 l\u00E1 m\u00F3c l\u00E1 c\u1ECD, d\u00F9ng l\u00E0m qu\u1EA1t g\u1ECDi l\u00E0 qu\u1EF3 phi\u1EBFn [\u8475\u6247].","level":["N1"],"examples":[{"w":"\u8475","m":"c\u00E2y th\u1EE5c qu\u1EF3","p":"\u3042\u304A\u3044","h":"QU\u1EF2"},{"w":"\u620E\u8475","m":"c\u00E2y th\u1EE5c qu\u1EF3","p":"\u3048\u3073\u3059\u307E\u3082\u308B","h":"NHUNG QU\u1EF2"},{"w":"\u7ACB\u8475","m":"c\u00E2y th\u1EE5c qu\u1EF3","p":"\u305F\u3061\u3042\u304A\u3044","h":"L\u1EACP QU\u1EF2"},{"w":"\u8475\u82B1","m":"c\u00E2y h\u01B0\u1EDBng d\u01B0\u01A1ng","p":"\u3042\u304A\u3044\u306F\u306A","h":"QU\u1EF2 HOA"},{"w":"\u82B1\u8475","m":"hoa th\u1EE5c qu\u1EF3; c\u00E2y th\u1EE5c qu\u1EF3 .","p":" \u306F\u306A\u3042\u304A\u3044","h":"HOA QU\u1EF2"},{"w":"\u7ACB\u3061\u8475","m":"c\u00E2y th\u1EE5c qu\u1EF3","p":"\u305F\u3061\u3042\u304A\u3044","h":"L\u1EACP QU\u1EF2"},{"w":"\u5411\u65E5\u8475","m":"Hoa h\u01B0\u1EDBng d\u01B0\u01A1ng .","p":" \u3072\u307E\u308F\u308A","h":"H\u01AF\u1EDANG NH\u1EACT QU\u1EF2"},{"w":"\u5929\u7AFA\u8475","m":"C\u00E2y phong l\u1EEF th\u1EA3o .","p":" \u3066\u3093\u3058\u304F\u3042\u304A\u3044","h":"THI\u00CAN TR\u00DAC QU\u1EF2"}]}